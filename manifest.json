{
  "manifest_version": 3,
  "name": "Mangalib Ultimate Helper",
  "version": "3.10",
  "description": "Модерация, командная панель, чтение, персонализация для сайтов семейства Lib",

  "browser_specific_settings": {
    "gecko": {
      "id": "mangalib-ultimate@maybegod2020",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://mangalib.me/*",
    "https://ranobelib.me/*",
    "https://hentailib.me/*",
    "https://v2.shlib.life/*",
    "https://v5.animelib.org/*",
    "https://api.cdnlibs.org/*",
    "https://mangalib-moderation-default-rtdb.europe-west1.firebasedatabase.app/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.x.ai/*",
    "https://api.mistral.ai/*"
  ],

  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": [
        "https://mangalib.me/*",
        "https://ranobelib.me/*",
        "https://hentailib.me/*",
        "https://v2.shlib.life/*",
        "https://v5.animelib.org/*"
      ],
      "js": [
        "lib/shared.js",
        "lib/settings-store.js",
        "modules/personalization.js",
        "modules/reader.js",
        "modules/moderation.js",
        "modules/ai-verdict.js",
        "modules/dashboard.js",
        "modules/settings-ui.js",
        "modules/user-tooltip.js",
        "main.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
